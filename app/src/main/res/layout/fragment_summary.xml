<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg">

    <!-- Tab row: Farmer View | Expert Mode -->
    <LinearLayout
        android:id="@+id/tabRow"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@color/white"
        android:elevation="2dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tabFarmer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/tab_farmer_view"
            android:textColor="@color/agri_green"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_tab_active" />

        <TextView
            android:id="@+id/tabExpert"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/tab_expert_mode"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- FARMER VIEW panel -->
    <ScrollView
        android:id="@+id/panelFarmer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/btnBackHome"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabRow">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/test_completed"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="@string/summary_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <!-- Summary card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_summary_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="@string/summary_header"
                    android:textAllCaps="true"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvTestType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Test Type: —"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="14dp" android:background="@color/divider" />

                <TextView
                    android:id="@+id/tvResultVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Result Value: —"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="14dp" android:background="@color/divider" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status: —"
                    android:textColor="@color/agri_green"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- EXPERT VIEW panel (hidden by default) -->
    <ScrollView
        android:id="@+id/panelExpert"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btnBackHome"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabRow">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Expert badge + title -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_expert_badge"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:text="@string/expert_badge"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/expert_title"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Stats 2x3 grid using nested LinearLayouts -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="14dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="6dp" android:background="@drawable/bg_stat_card" android:orientation="vertical" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_peak_current" android:textColor="@color/text_secondary" android:textSize="11sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2.34 µA" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="6dp" android:background="@drawable/bg_stat_card" android:orientation="vertical" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_peak_potential" android:textColor="@color/text_secondary" android:textSize="11sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="–0.24 V" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="6dp" android:background="@drawable/bg_stat_card" android:orientation="vertical" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_technique" android:textColor="@color/text_secondary" android:textSize="11sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DPV" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="6dp" android:background="@drawable/bg_stat_card" android:orientation="vertical" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_temperature" android:textColor="@color/text_secondary" android:textSize="11sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="28.4 °C" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="6dp" android:background="@drawable/bg_stat_card" android:orientation="vertical" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_scan_rate" android:textColor="@color/text_secondary" android:textSize="11sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.1 V/s" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="6dp" android:background="@drawable/bg_stat_card" android:orientation="vertical" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_strip_id" android:textColor="@color/text_secondary" android:textSize="11sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OP-v1" android:textColor="@color/text_primary" android:textSize="15sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- DPV Chart card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="@string/chart_title"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <!-- SVG chart rendered as custom view via WebView for simplicity -->
                <android.webkit.WebView
                    android:id="@+id/chartWebView"
                    android:layout_width="match_parent"
                    android:layout_height="120dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Back to Home button — always pinned to bottom -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackHome"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        android:text="@string/btn_back_home"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/agri_green"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
